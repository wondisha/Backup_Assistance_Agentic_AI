-- =====================================================
-- SNOWFLAKE BACKUP ASSISTANT AGENT - Complete Setup
-- Repository: github.com/wondisha
-- =====================================================
-- This script creates a Cortex Agent for managing Snowflake 
-- database, schema, and table backups with full automation.

-- =====================================================
-- STEP 1: CREATE DATABASE AND SCHEMA
-- =====================================================
CREATE DATABASE IF NOT EXISTS BACKUP_AGENT_DB;
CREATE SCHEMA IF NOT EXISTS BACKUP_AGENT_DB.BACKUP_TOOLS;

USE DATABASE BACKUP_AGENT_DB;
USE SCHEMA BACKUP_TOOLS;

-- =====================================================
-- STEP 2: STORED PROCEDURES FOR BACKUP OPERATIONS
-- =====================================================

-- Procedure: Create a backup set for a table
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_TABLE_BACKUP_SET(
    BACKUP_SET_NAME VARCHAR,
    DATABASE_NAME VARCHAR,
    SCHEMA_NAME VARCHAR,
    TABLE_NAME VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'CREATE BACKUP SET ' || BACKUP_SET_NAME || 
        ' FOR TABLE ' || DATABASE_NAME || '.' || SCHEMA_NAME || '.' || TABLE_NAME;
    RETURN 'Backup set ' || BACKUP_SET_NAME || ' created successfully for table ' || 
        DATABASE_NAME || '.' || SCHEMA_NAME || '.' || TABLE_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error creating backup set: ' || SQLERRM;
END;
$$;

-- Procedure: Create a backup set for a schema
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_SCHEMA_BACKUP_SET(
    BACKUP_SET_NAME VARCHAR,
    DATABASE_NAME VARCHAR,
    SCHEMA_NAME VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'CREATE BACKUP SET ' || BACKUP_SET_NAME || 
        ' FOR SCHEMA ' || DATABASE_NAME || '.' || SCHEMA_NAME;
    RETURN 'Backup set ' || BACKUP_SET_NAME || ' created successfully for schema ' || 
        DATABASE_NAME || '.' || SCHEMA_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error creating backup set: ' || SQLERRM;
END;
$$;

-- Procedure: Create a backup set for a database
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_DATABASE_BACKUP_SET(
    BACKUP_SET_NAME VARCHAR,
    DATABASE_NAME VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'CREATE BACKUP SET ' || BACKUP_SET_NAME || 
        ' FOR DATABASE ' || DATABASE_NAME;
    RETURN 'Backup set ' || BACKUP_SET_NAME || ' created successfully for database ' || DATABASE_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error creating backup set: ' || SQLERRM;
END;
$$;

-- Procedure: Create a backup set with a backup policy
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_BACKUP_SET_WITH_POLICY(
    BACKUP_SET_NAME VARCHAR,
    OBJECT_TYPE VARCHAR,
    OBJECT_FULL_NAME VARCHAR,
    POLICY_NAME VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'CREATE BACKUP SET ' || BACKUP_SET_NAME || 
        ' FOR ' || OBJECT_TYPE || ' ' || OBJECT_FULL_NAME || 
        ' WITH BACKUP POLICY ' || POLICY_NAME;
    RETURN 'Backup set ' || BACKUP_SET_NAME || ' created with policy ' || POLICY_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error creating backup set with policy: ' || SQLERRM;
END;
$$;

-- Procedure: Add a manual backup to a backup set
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.ADD_BACKUP(
    BACKUP_SET_NAME VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'ALTER BACKUP SET ' || BACKUP_SET_NAME || ' ADD BACKUP';
    RETURN 'Backup added successfully to backup set ' || BACKUP_SET_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error adding backup: ' || SQLERRM;
END;
$$;

-- Procedure: List backups in a backup set
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.LIST_BACKUPS(
    BACKUP_SET_NAME VARCHAR
)
RETURNS TABLE(CREATED_ON TIMESTAMP_LTZ, BACKUP_ID VARCHAR, EXPIRE_ON TIMESTAMP_LTZ)
LANGUAGE SQL
AS
$$
DECLARE
    res RESULTSET;
BEGIN
    res := (EXECUTE IMMEDIATE 'SHOW BACKUPS IN BACKUP SET ' || BACKUP_SET_NAME);
    RETURN TABLE(res);
END;
$$;

-- Procedure: Create a backup policy
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_BACKUP_POLICY(
    POLICY_NAME VARCHAR,
    SCHEDULE_MINUTES INT,
    EXPIRE_AFTER_DAYS INT
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'CREATE BACKUP POLICY ' || POLICY_NAME || 
        ' SCHEDULE = ''' || SCHEDULE_MINUTES || ' MINUTE'' EXPIRE_AFTER_DAYS = ' || EXPIRE_AFTER_DAYS;
    RETURN 'Backup policy ' || POLICY_NAME || ' created with schedule every ' || 
        SCHEDULE_MINUTES || ' minutes and expiration after ' || EXPIRE_AFTER_DAYS || ' days';
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error creating backup policy: ' || SQLERRM;
END;
$$;

-- Procedure: Suspend backup policy on a backup set
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.SUSPEND_BACKUP_POLICY(
    BACKUP_SET_NAME VARCHAR,
    SUSPEND_TYPE VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
DECLARE
    CMD VARCHAR;
BEGIN
    CASE UPPER(SUSPEND_TYPE)
        WHEN 'ALL' THEN
            CMD := 'ALTER BACKUP SET ' || BACKUP_SET_NAME || ' SUSPEND BACKUP POLICY';
        WHEN 'CREATION' THEN
            CMD := 'ALTER BACKUP SET ' || BACKUP_SET_NAME || ' SUSPEND BACKUP CREATION POLICY';
        WHEN 'EXPIRATION' THEN
            CMD := 'ALTER BACKUP SET ' || BACKUP_SET_NAME || ' SUSPEND BACKUP EXPIRATION POLICY';
        ELSE
            RETURN 'Invalid suspend type. Use ALL, CREATION, or EXPIRATION';
    END CASE;
    EXECUTE IMMEDIATE CMD;
    RETURN 'Backup policy ' || SUSPEND_TYPE || ' suspended on backup set ' || BACKUP_SET_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error suspending backup policy: ' || SQLERRM;
END;
$$;

-- Procedure: Resume backup policy on a backup set
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.RESUME_BACKUP_POLICY(
    BACKUP_SET_NAME VARCHAR,
    RESUME_TYPE VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
DECLARE
    CMD VARCHAR;
BEGIN
    CASE UPPER(RESUME_TYPE)
        WHEN 'ALL' THEN
            CMD := 'ALTER BACKUP SET ' || BACKUP_SET_NAME || ' RESUME BACKUP POLICY';
        WHEN 'CREATION' THEN
            CMD := 'ALTER BACKUP SET ' || BACKUP_SET_NAME || ' RESUME BACKUP CREATION POLICY';
        WHEN 'EXPIRATION' THEN
            CMD := 'ALTER BACKUP SET ' || BACKUP_SET_NAME || ' RESUME BACKUP EXPIRATION POLICY';
        ELSE
            RETURN 'Invalid resume type. Use ALL, CREATION, or EXPIRATION';
    END CASE;
    EXECUTE IMMEDIATE CMD;
    RETURN 'Backup policy ' || RESUME_TYPE || ' resumed on backup set ' || BACKUP_SET_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error resuming backup policy: ' || SQLERRM;
END;
$$;

-- Procedure: Restore a table from backup
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.RESTORE_TABLE(
    NEW_TABLE_NAME VARCHAR,
    BACKUP_SET_NAME VARCHAR,
    BACKUP_ID VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'CREATE TABLE ' || NEW_TABLE_NAME || 
        ' FROM BACKUP SET ' || BACKUP_SET_NAME || ' IDENTIFIER ''' || BACKUP_ID || '''';
    RETURN 'Table restored as ' || NEW_TABLE_NAME || ' from backup ' || BACKUP_ID;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error restoring table: ' || SQLERRM;
END;
$$;

