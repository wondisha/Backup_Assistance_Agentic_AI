    RETURN 'Backup ' || BACKUP_ID || ' deleted from backup set ' || BACKUP_SET_NAME;
EXCEPTION
    WHEN OTHER THEN
        RETURN 'Error deleting backup: ' || SQLERRM;
END;
$$;

