$$;

-- =====================================================
-- STEP 3: CREATE THE CORTEX AGENT
-- =====================================================

CREATE OR REPLACE AGENT BACKUP_AGENT_DB.BACKUP_TOOLS.BACKUP_ASSISTANT
    COMMENT = 'Cortex Agent for managing Snowflake database, schema, and table backups'
    FROM SPECIFICATION
    $$
    models:
      orchestration: claude-4-sonnet

    orchestration:
      budget:
        seconds: 60
        tokens: 16000

    instructions:
      system: |
        You are a Snowflake Backup Assistant that helps users manage database, schema, and table backups.
        You can create backup sets, add backups, restore from backups, manage backup policies, and handle legal holds.
        
        Key concepts:
        - Backup Set: A container that holds backups for a specific table, schema, or database
        - Backup Policy: Defines automatic backup schedule and expiration
        - Legal Hold: Prevents a backup from being deleted for compliance purposes
        
        Important rules:
        - Only the oldest backup without legal hold can be deleted from a backup set
        - Backups can only be restored to a new object name, not overwrite existing objects
        - When restoring, the backup_id must be obtained from listing backups first
        
      orchestration: |
        For backup operations:
        - Use create_table_backup_set, create_schema_backup_set, or create_database_backup_set to create new backup sets
        - Use add_backup to manually trigger a backup
        - Use list_backups to see available backups and get backup_id for restore
        - Use restore_table, restore_schema, or restore_database to restore from backup
        - Use create_backup_policy and create_backup_set_with_policy for scheduled backups
        - Use apply_backup_policy to attach a policy to an existing backup set
        - Use suspend_backup_policy and resume_backup_policy to manage policy execution
        - Use add_legal_hold and remove_legal_hold for compliance requirements
        
      response: |
        Provide clear, concise responses about backup operations.
        When listing backups, format the output as a table showing backup_id, created_on, and expire_on.
        Always confirm the action taken and any important next steps.

    tools:
      - tool_spec:
          type: "generic"
          name: "create_table_backup_set"
          description: "Creates a new backup set for a specific table."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name for the new backup set"
              database_name:
                type: "string"
                description: "Database containing the table"
              schema_name:
                type: "string"
                description: "Schema containing the table"
              table_name:
                type: "string"
                description: "Name of the table to backup"
            required: ["backup_set_name", "database_name", "schema_name", "table_name"]

      - tool_spec:
          type: "generic"
          name: "create_schema_backup_set"
          description: "Creates a new backup set for an entire schema."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name for the new backup set"
              database_name:
                type: "string"
                description: "Database containing the schema"
              schema_name:
                type: "string"
                description: "Name of the schema to backup"
            required: ["backup_set_name", "database_name", "schema_name"]

      - tool_spec:
          type: "generic"
          name: "create_database_backup_set"
          description: "Creates a new backup set for an entire database."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name for the new backup set"
              database_name:
                type: "string"
                description: "Name of the database to backup"
            required: ["backup_set_name", "database_name"]

      - tool_spec:
          type: "generic"
          name: "create_backup_policy"
          description: "Creates a backup policy with schedule and expiration."
          input_schema:
            type: "object"
            properties:
              policy_name:
                type: "string"
                description: "Name for the backup policy"
              schedule_minutes:
                type: "integer"
                description: "Backup frequency in minutes (60=hourly, 1440=daily, 10080=weekly)"
              expire_after_days:
                type: "integer"
                description: "Days after which backups expire"
            required: ["policy_name", "schedule_minutes", "expire_after_days"]

      - tool_spec:
          type: "generic"
          name: "create_backup_set_with_policy"
          description: "Creates a backup set with an associated backup policy."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name for the new backup set"
              object_type:
                type: "string"
                description: "Type: TABLE, SCHEMA, or DATABASE"
              object_full_name:
                type: "string"
                description: "Fully qualified object name"
              policy_name:
                type: "string"
                description: "Name of the backup policy"
            required: ["backup_set_name", "object_type", "object_full_name", "policy_name"]

      - tool_spec:
          type: "generic"
          name: "apply_backup_policy"
          description: "Applies a backup policy to an existing backup set."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              policy_name:
                type: "string"
                description: "Fully qualified policy name to apply"
            required: ["backup_set_name", "policy_name"]

      - tool_spec:
          type: "generic"
          name: "add_backup"
          description: "Manually triggers a backup."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
            required: ["backup_set_name"]

      - tool_spec:
          type: "generic"
          name: "list_backups"
          description: "Lists all backups in a backup set."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
            required: ["backup_set_name"]

      - tool_spec:
          type: "generic"
          name: "list_backup_sets"
          description: "Lists all backup sets in the account."
          input_schema:
            type: "object"
            properties: {}

      - tool_spec:
          type: "generic"
          name: "restore_table"
          description: "Restores a table from a backup."
          input_schema:
            type: "object"
            properties:
              new_table_name:
                type: "string"
                description: "Fully qualified name for restored table"
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              backup_id:
                type: "string"
                description: "UUID of the backup"
            required: ["new_table_name", "backup_set_name", "backup_id"]

      - tool_spec:
          type: "generic"
          name: "restore_schema"
          description: "Restores a schema from a backup."
          input_schema:
            type: "object"
            properties:
              new_schema_name:
                type: "string"
                description: "Fully qualified name for restored schema"
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              backup_id:
                type: "string"
                description: "UUID of the backup"
            required: ["new_schema_name", "backup_set_name", "backup_id"]

      - tool_spec:
          type: "generic"
          name: "restore_database"
          description: "Restores a database from a backup."
          input_schema:
            type: "object"
            properties:
              new_database_name:
                type: "string"
                description: "Name for restored database"
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              backup_id:
                type: "string"
                description: "UUID of the backup"
            required: ["new_database_name", "backup_set_name", "backup_id"]

      - tool_spec:
          type: "generic"
          name: "suspend_backup_policy"
          description: "Suspends a backup policy on a backup set."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              suspend_type:
                type: "string"
                description: "ALL, CREATION, or EXPIRATION"
            required: ["backup_set_name", "suspend_type"]

      - tool_spec:
          type: "generic"
          name: "resume_backup_policy"
          description: "Resumes a suspended backup policy."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              resume_type:
                type: "string"
                description: "ALL, CREATION, or EXPIRATION"
            required: ["backup_set_name", "resume_type"]

      - tool_spec:
          type: "generic"
          name: "delete_backup"
          description: "Deletes the oldest backup without legal hold."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              backup_id:
                type: "string"
                description: "UUID of the backup to delete"
            required: ["backup_set_name", "backup_id"]

      - tool_spec:
          type: "generic"
          name: "drop_backup_set"
          description: "Drops an entire backup set."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set to drop"
            required: ["backup_set_name"]

      - tool_spec:
          type: "generic"
          name: "add_legal_hold"
          description: "Adds a legal hold to a backup for compliance."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              backup_id:
                type: "string"
                description: "UUID of the backup"
            required: ["backup_set_name", "backup_id"]

      - tool_spec:
          type: "generic"
          name: "remove_legal_hold"
          description: "Removes a legal hold from a backup."
          input_schema:
            type: "object"
            properties:
              backup_set_name:
                type: "string"
                description: "Name of the backup set"
              backup_id:
                type: "string"
                description: "UUID of the backup"
            required: ["backup_set_name", "backup_id"]

    tool_resources:
      create_table_backup_set:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_TABLE_BACKUP_SET"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      create_schema_backup_set:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_SCHEMA_BACKUP_SET"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      create_database_backup_set:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_DATABASE_BACKUP_SET"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      create_backup_policy:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_BACKUP_POLICY"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      create_backup_set_with_policy:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.CREATE_BACKUP_SET_WITH_POLICY"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      apply_backup_policy:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.APPLY_BACKUP_POLICY"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      add_backup:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.ADD_BACKUP"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      list_backups:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.LIST_BACKUPS"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      list_backup_sets:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.LIST_BACKUP_SETS"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      restore_table:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.RESTORE_TABLE"
        execution_environment:
          type: "warehouse"
          warehouse: "COMPUTE_WH"

      restore_schema:
        type: "procedure"
        identifier: "BACKUP_AGENT_DB.BACKUP_TOOLS.RESTORE_SCHEMA"
