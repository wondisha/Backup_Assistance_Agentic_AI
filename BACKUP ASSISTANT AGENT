-- Procedure: Delete a backup from a backup set (oldest only)
CREATE OR REPLACE PROCEDURE BACKUP_AGENT_DB.BACKUP_TOOLS.DELETE_BACKUP(
    BACKUP_SET_NAME VARCHAR,
    BACKUP_ID VARCHAR
)
RETURNS VARCHAR
LANGUAGE SQL
AS
$$
BEGIN
    EXECUTE IMMEDIATE 'ALTER BACKUP SET ' || BACKUP_SET_NAME || 
